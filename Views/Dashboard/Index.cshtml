@{
    ViewData["Title"] = "الرئيسية";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px;">
    <div class="card" style="border-right: 4px solid var(--gold);">
        <h3 style="margin:0 0 10px; color:var(--text-soft); font-size:1rem;">إجمالي الطلاب</h3>
        <div style="font-size: 2.2rem; font-weight: 900; color: var(--gold);">@ViewBag.TotalStudents</div>
    </div>
    
    <div class="card" style="border-right: 4px solid #4CAF50;">
        <h3 style="margin:0 0 10px; color:var(--text-soft); font-size:1rem;">الحلقات القرآنية</h3>
        <div style="font-size: 2.2rem; font-weight: 900; color: #4CAF50;">@ViewBag.TotalHalaqas</div>
    </div>
    
    <div class="card" style="border-right: 4px solid #2196F3;">
        <h3 style="margin:0 0 10px; color:var(--text-soft); font-size:1rem;">المعلمون</h3>
        <div style="font-size: 2.2rem; font-weight: 900; color: #2196F3;">@ViewBag.TotalTeachers</div>
    </div>

    <div class="card" style="border-right: 4px solid #ff9800; @(ViewBag.PendingRequests > 0 ? "background:#fff8e1;" : "")">
        <h3 style="margin:0 0 10px; color:var(--text-soft); font-size:1rem;">⏳ طلبات التسجيل</h3>
        <div style="font-size: 2.2rem; font-weight: 900; color: #ff9800;">
            @ViewBag.PendingRequests
            @if (ViewBag.PendingRequests > 0)
            {
                <a href="/Dashboard/RegistrationRequests" class="btn" style="font-size:.8rem;padding:6px 14px;background:#ff9800;box-shadow:none;margin-right:10px;">عرض الطلبات</a>
            }
        </div>
    </div>
</div>

<div class="card" style="margin-top: 24px; display:flex; align-items:center; gap:20px; flex-wrap:wrap;">
    <img src="/image/taj-el-waqar-logo.jpg" alt="تاج الوقار" style="width:70px;height:70px;border-radius:50%;object-fit:cover;border:3px solid var(--gold-pale);flex-shrink:0">
    <div style="flex:1;min-width:200px">
        <h3 style="margin:0 0 10px; color:var(--gold);">مرحباً بك في لوحة الإدارة</h3>
        <p style="color:var(--text-soft); line-height: 1.8;margin:0">
            من خلال هذه اللوحة يمكنك إدارة شؤون الطلاب، الحلقات، ومتابعة الحفظ والحضور.<br>
            استخدم القائمة الجانبية للوصول إلى أقسام النظام.
        </p>
    </div>
</div>
