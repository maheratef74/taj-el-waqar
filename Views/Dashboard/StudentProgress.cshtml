@model ElMaherQuranSchool.Models.Student
@{
    ViewData["Title"] = "متابعة الطالب";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card" style="margin-bottom: 24px; border-top: 4px solid var(--gold);">
    <div style="display:flex; justify-content: space-between; align-items: center; flex-wrap: wrap;">
        <div>
            <h2 style="margin:0 0 8px; color:var(--text-dark);">@Model.Name</h2>
            <div style="color:var(--text-soft); font-weight:600; font-size:.95rem; line-height:1.8;">
                الرقم التسلسلي: <span style="color:var(--text-dark);">@Model.SerialNumber</span> | 
                النقاط: <span style="color:#2196F3; font-weight:900;">@Model.PointProgress</span> <button onclick="document.getElementById('pointsModal').style.display='flex'" style="background:none; border:none; cursor:pointer;" title="تحديث النقاط">✏️</button> | 
                إجمالي الأوجه: <span style="color:var(--gold); font-weight:900;">@Model.TotalMemorizedPages</span> <button onclick="document.getElementById('totalMemorizedModal').style.display='flex'" style="background:none; border:none; cursor:pointer;" title="تحديث إجمالي الأوجه">✏️</button> | 
                الحلقة: @(Model.Halaqa != null ? Model.Halaqa.Name : "غير مسجل بحلقة")
            </div>
        </div>
        <div>
            <a href="/Dashboard/Students" class="btn" style="background:var(--beige-dark); color:var(--text-dark); box-shadow:none;">العودة للقائمة</a>
        </div>
    </div>
</div>

@if (TempData["Error"] != null)
{
    <div style="background: #ffebee; color: #c62828; padding: 14px; border-radius: 8px; margin-bottom: 24px; font-weight: 700;">
        @TempData["Error"]
    </div>
}

@if (TempData["Success"] != null)
{
    <div style="background: #e8f5e9; color: #2e7d32; padding: 14px; border-radius: 8px; margin-bottom: 24px; font-weight: 700;">
        @TempData["Success"]
    </div>
}

@if (Model.Halaqa == null)
{
    <div style="background: #fff3e0; color: #e65100; padding: 20px; border-radius: 8px; font-weight: 700; text-align: center;">
        يجب تعيين الطالب في حلقة أولاً قبل التمكن من تسجيل حضوره.
        <br><br>
        <a href="/Dashboard/EditStudent/@Model.Id" class="btn">تعيين في حلقة</a>
    </div>
}
else
{
    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;">
        <!-- Add Points Form -->
        <div class="card">
            <h3 style="margin: 0 0 20px; color: var(--gold); border-bottom: 2px solid var(--gold-pale); padding-bottom: 10px;">تسجيل جديد</h3>
            
            <form method="post" action="/Dashboard/AddSessionRecord">
                <input type="hidden" name="studentId" value="@Model.Id" />
                
                <div style="margin-bottom: 16px;">
                    <label class="form-label">تاريخ الجلسة</label>
                    <input type="date" class="form-control" name="sessionDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                </div>

                <div style="margin-bottom: 16px;">
                    <label class="form-label">حالة الحضور</label>
                    <select class="form-control" name="isPresent" required>
                        <option value="true">حاضر</option>
                        <option value="false">غائب</option>
                    </select>
                </div>

                <div style="margin-bottom: 16px;">
                    <label class="form-label">نقاط الحضور والانتظام</label>
                    <input type="number" class="form-control" name="attendanceScore" value="0" min="0" max="100" required />
                </div>

                <div style="margin-bottom: 16px;">
                    <label class="form-label">درجة الحفظ</label>
                    <input type="number" class="form-control" name="memorizationScore" value="0" min="0" max="100" required />
                </div>

                <div style="margin-bottom: 20px;">
                    <label class="form-label">ملاحظات المعلم (اختياري)</label>
                    <textarea class="form-control" name="teacherNote" rows="3" placeholder="ملاحظات حول أداء الطالب..."></textarea>
                </div>

                <button type="submit" class="btn" style="width:100%;">💾 حفظ السجل</button>
            </form>
        </div>

        <!-- History Table -->
        <div class="card">
            <h3 style="margin: 0 0 20px; color: var(--gold); border-bottom: 2px solid var(--gold-pale); padding-bottom: 10px;">سجل الحضور الأخير</h3>

            <div class="table-responsive">
                <table>
                    <thead>
                        <tr>
                            <th>التاريخ</th>
                            <th>الحضور</th>
                            <th>النقاط</th>
                            <th>ملاحظات</th>
                            <th>إجراءات</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var record in Model.SessionRecords)
                        {
                            <tr>
                                <td style="font-weight:bold;">@record.Session.SessionDate.ToString("yyyy/MM/dd")</td>
                                <td>
                                    @if(record.IsPresent) { <span style="color:#4CAF50; font-weight:bold;">حاضر</span> }
                                    else { <span style="color:#f44336; font-weight:bold;">غائب</span> }
                                </td>
                                <td><span style="background:var(--beige-dark); padding:4px 8px; border-radius:4px; font-weight:bold;">@record.AttendanceScore</span></td>
                                <td style="font-size:.85rem; color:var(--text-soft); max-width: 150px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="@record.TeacherNote">
                                    @(string.IsNullOrEmpty(record.TeacherNote) ? "-" : record.TeacherNote)
                                </td>
                                <td>
                                    <form method="post" action="/Dashboard/DeleteSessionRecord" style="display:inline;" onsubmit="return confirmDelete(this, 'هل أنت متأكد من حذف هذا السجل؟ سيتم خصم @record.AttendanceScore نقطة من إجمالي نقاط الطالب.')">
                                        <input type="hidden" name="recordId" value="@record.Id" />
                                        <button type="submit" style="background:none; border:none; color:#f44336; cursor:pointer; font-size:1.1rem;" title="حذف السجل">🗑️</button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                
                @if(!Model.SessionRecords.Any())
                {
                    <div style="text-align:center; padding: 20px; color:var(--text-soft);">
                        لم يتم تسجيل أي حضور أو تقييم للطالب حتى الآن.
                    </div>
                }
            </div>
        </div>
    </div>
}

<div id="pointsModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center; backdrop-filter: blur(2px);">
    <div class="card" style="width:100%; max-width:400px; margin:20px;">
        <h3 style="margin:0 0 20px; color:var(--text-dark);">تحديث نقاط الإنجاز</h3>
        <form method="post" action="/Dashboard/UpdatePointProgress">
            <input type="hidden" name="studentId" value="@Model.Id" />
            <div style="margin-bottom:20px;">
                <label class="form-label">النقاط الحالية: @Model.PointProgress</label>
                <input type="number" name="newPoints" class="form-control" value="@Model.PointProgress" required min="0" />
            </div>
            <div style="display:flex; justify-content:flex-end; gap:10px;">
                <button type="button" class="btn" style="background:var(--beige-dark); color:var(--text-dark); box-shadow:none;" onclick="document.getElementById('pointsModal').style.display='none'">إلغاء</button>
                <button type="submit" class="btn" style="background:#2196F3;">حفظ</button>
            </div>
        </form>
    </div>
</div>

<div id="pagesModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center; backdrop-filter: blur(2px);">
    <div class="card" style="width:100%; max-width:400px; margin:20px;">
        <h3 style="margin:0 0 20px; color:var(--text-dark);">تحديث إنجاز الأوجه</h3>
        <form method="post" action="/Dashboard/UpdatePagesProgress">
            <input type="hidden" name="studentId" value="@Model.Id" />
            <div style="margin-bottom:20px;">
                <label class="form-label">الأوجه المنجزة: @Model.TotalMemorizedPages</label>
                <input type="number" name="newPages" class="form-control" value="@Model.TotalMemorizedPages" required min="0" />
            </div>
            <div style="display:flex; justify-content:flex-end; gap:10px;">
                <button type="button" class="btn" style="background:var(--beige-dark); color:var(--text-dark); box-shadow:none;" onclick="document.getElementById('pagesModal').style.display='none'">إلغاء</button>
                <button type="submit" class="btn" style="background:#4CAF50;">حفظ</button>
            </div>
        </form>
    </div>
</div>

<div id="totalMemorizedModal" style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); z-index:1000; align-items:center; justify-content:center; backdrop-filter: blur(2px);">
    <div class="card" style="width:100%; max-width:400px; margin:20px;">
        <h3 style="margin:0 0 20px; color:var(--text-dark);">تحديث إجمالي الأوجه</h3>
        <form method="post" action="/Dashboard/UpdateTotalMemorizedPages">
            <input type="hidden" name="studentId" value="@Model.Id" />
            <div style="margin-bottom:20px;">
                <label class="form-label">إجمالي الأوجه: @Model.TotalMemorizedPages</label>
                <input type="number" name="newTotalPages" class="form-control" value="@Model.TotalMemorizedPages" required min="0" />
            </div>
            <div style="display:flex; justify-content:flex-end; gap:10px;">
                <button type="button" class="btn" style="background:var(--beige-dark); color:var(--text-dark); box-shadow:none;" onclick="document.getElementById('totalMemorizedModal').style.display='none'">إلغاء</button>
                <button type="submit" class="btn" style="background:var(--gold);">حفظ</button>
            </div>
        </form>
    </div>
</div>
