@model Halaqa
@{
    ViewData["Title"] = "تعديل الحلقة";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var teachers = ViewBag.Teachers as IEnumerable<ElMaherQuranSchool.Models.Teacher>;
}

<div class="card" style="max-width: 700px; margin: 0 auto;">
    <h3 style="margin: 0 0 24px; color: var(--gold); border-bottom: 2px solid var(--gold-pale); padding-bottom: 12px;">تعديل بيانات الحلقة</h3>

    @Html.ValidationSummary(true, "", new { style="color:red; margin-bottom:15px; font-weight:bold;" })

    <form method="post" action="/Dashboard/EditHalaqa">
        <input type="hidden" name="id" value="@Model.Id" />

        <div style="margin-bottom: 20px;">
            <label class="form-label" for="Name">اسم الحلقة *</label>
            <input type="text" class="form-control" id="Name" name="Name" value="@Model.Name" placeholder="مثال: حلقة النور، حلقة البراعم..." required />
        </div>

        <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 16px;">
            <div style="margin-bottom: 20px;">
                <label class="form-label" for="Level">المستوى</label>
                <select class="form-control" id="Level" name="Level">
                    <option value="">-- اختر المستوى --</option>
                    <option value="مبتدئ" selected="@(Model.Level == "مبتدئ")">🧒 مبتدئ (للأطفال)</option>
                    <option value="متوسط" selected="@(Model.Level == "متوسط")">📖 متوسط</option>
                    <option value="متقدم" selected="@(Model.Level == "متقدم")">⭐ متقدم</option>
                    <option value="تجويد" selected="@(Model.Level == "تجويد")">🎓 تجويد</option>
                </select>
            </div>

            <div style="margin-bottom: 20px;">
                <label class="form-label" for="Location">الفرع</label>
                <select class="form-control" id="Location" name="Location">
                    <option value="">-- اختر الفرع --</option>
                    <option value="دوار اللبيدي" selected="@(Model.Location == "دوار اللبيدي")">دوار اللبيدي</option>
                </select>
            </div>

            <div style="margin-bottom: 20px;">
                <label class="form-label" for="AgeRange">الفئة العمرية</label>
                <input type="text" class="form-control" id="AgeRange" name="AgeRange" value="@Model.AgeRange" placeholder="مثال: 6 – 10 سنوات" />
            </div>

            <div style="margin-bottom: 20px;">
                <label class="form-label" for="ClassTime">الوقت</label>
                <input type="text" class="form-control" id="ClassTime" name="ClassTime" value="@Model.ClassTime" placeholder="مثال: 4:00 – 5:30 م" />
            </div>

            <div style="margin-bottom: 20px;">
                <label class="form-label" for="Schedule">المواعيد</label>
                <input type="text" class="form-control" id="Schedule" name="Schedule" value="@Model.Schedule" placeholder="مثال: السبت – الخميس" />
            </div>

            <div style="margin-bottom: 20px;">
                <label class="form-label" for="MaxCapacity">الطاقة الاستيعابية</label>
                <input type="number" class="form-control" id="MaxCapacity" name="MaxCapacity" value="@Model.MaxCapacity" min="1" />
            </div>
        </div>

        <div style="margin-bottom: 20px;">
            <label class="form-label" for="TargetPages">عدد الأوجه لإتمام الحلقة (الهدف التقريبي)</label>
            <input type="number" class="form-control" id="TargetPages" name="TargetPages" value="@Model.TargetPages" min="1" required />
            <small style="color:var(--text-light); font-size:12px; margin-top:5px; display:block;">سيتم استخدام هذا العدد لرسم نسبة إنجاز الطالب في ملفه العام</small>
        </div>

        <div style="margin-bottom: 20px;">
            <label class="form-label" for="Description">الوصف (اختياري)</label>
            <input type="text" class="form-control" id="Description" name="Description" value="@Model.Description" placeholder="تفاصيل إضافية عن الحلقة..." />
        </div>

        <div style="margin-bottom: 24px;">
            <label class="form-label" for="TeacherId">تعيين معلم (اختياري)</label>
            <select class="form-control" id="TeacherId" name="TeacherId">
                <option value="">-- اختر معلماً --</option>
                @if (teachers != null)
                {
                    foreach (var t in teachers)
                    {
                        <option value="@t.Id" selected="@(Model.TeacherId == t.Id)">@t.Name</option>
                    }
                }
            </select>
        </div>

        <div style="display:flex; justify-content: flex-end; gap:10px;">
            <a href="/Dashboard/Halaqas" class="btn" style="background:#f44336; box-shadow:none;">إلغاء</a>
            <button type="submit" class="btn">💾 حفظ التعديلات</button>
        </div>
    </form>
</div>