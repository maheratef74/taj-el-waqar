@model IEnumerable<ElMaherQuranSchool.Models.Teacher>
@{
    ViewData["Title"] = "المعلمون";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card">
    <div style="display:flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap:wrap; gap:10px;">
        <h3 style="margin: 0; color: var(--gold);">قائمة المعلمين</h3>
        <a href="/Dashboard/AddTeacher" class="btn">➕ إضافة معلم</a>
    </div>

    <div class="table-responsive">
        <table>
            <thead>
                <tr>
                    <th>اسم المعلم</th>
                    <th>المسمى الوظيفي</th>
                    <th>نبذة</th>
                    <th>تاريخ التسجيل</th>
                    <th>الترتيب</th>
                    <th>الإجراءات</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var teacher in Model)
                {
                    <tr>
                        <td style="font-weight:bold; color:var(--text-dark);">@teacher.Name</td>
                        <td style="font-size: .9rem; color:var(--gold);">@(string.IsNullOrEmpty(teacher.Role) ? "-" : teacher.Role)</td>
                        <td style="font-size: .85rem; color:var(--text-soft); max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@teacher.Description">
                            @(string.IsNullOrEmpty(teacher.Description) ? "-" : teacher.Description)
                        </td>
                        <td style="font-size: .9rem;">@teacher.CreatedAt.ToString("yyyy/MM/dd")</td>
                        <td style="font-weight:bold; color:var(--text-dark); text-align:center;">@teacher.SortOrder</td>
                        <td>
                            <div style="display:flex; gap:5px;">
                                <a href="/Dashboard/EditTeacher?id=@teacher.Id" class="btn" style="padding: 4px 10px; font-size: .85rem; background: #e3f2fd; color: black;">✏️ تعديل</a>
                                <form method="post" action="/Dashboard/DeleteTeacher" style="display:inline;" onsubmit="return confirmDelete(this, 'هل أنت متأكد من حذف هذا المعلم؟ سيتم فصله عن الحلقات المسجل بها.')">
                                    <input type="hidden" name="id" value="@teacher.Id" />
                                    <button type="submit" class="btn" style="padding: 4px 10px; font-size: .85rem; background: #f44336; box-shadow:none;">🗑️ حذف</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        
        @if(!Model.Any())
        {
            <div style="text-align:center; padding: 40px 20px; color:var(--text-soft);">
                لا يوجد معلمون مسجلون حالياً.
            </div>
        }
    </div>
</div>
