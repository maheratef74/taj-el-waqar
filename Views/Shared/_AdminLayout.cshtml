<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - لوحة الإدارة</title>
    <link rel="manifest" href="/manifest-admin.json">
    <meta name="theme-color" content="#357434">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="default">
    <link rel="apple-touch-icon" href="/image/taj-el-waqar-logo.jpg">
    <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #357434;
            --gold-light: #4a8a49;
            --gold-pale: #e8f0ed;
            --accent-gold: #b8962e;
            --beige: #fefcf7; --beige-dark: #f0e9d6;
            --text-dark: #1a2b24; --text-soft: #4a5c54; --white: #ffffff;
            --sidebar-width: 250px;
        }
        body { margin: 0; padding: 0; font-family: 'Tajawal', sans-serif; background: #fdfbf7; color: var(--text-dark); display: flex; min-height: 100vh; }
        .sidebar { width: var(--sidebar-width); background: var(--white); box-shadow: 2px 0 20px rgba(44,36,22,0.05); display: flex; flex-direction: column; position: fixed; top: 0; bottom: 0; right: 0; z-index: 100; }
        .sidebar-header { padding: 20px 16px; text-align: center; border-bottom: 1px solid var(--beige-dark); margin-bottom: 20px; }
        .sidebar-header h2 { margin: 0; color: var(--gold); font-size: 1.3rem; font-weight: 900; }
        .nav-link { display: flex; align-items: center; padding: 14px 24px; color: var(--text-soft); font-weight: 700; text-decoration: none; font-size: .95rem; border-left: 4px solid transparent; transition: .2s; }
        .nav-link:hover { background: var(--beige); color: var(--gold); border-left-color: var(--gold-light); }
        .nav-link.active { background: var(--gold-pale); color: var(--gold); border-left-color: var(--gold); }
        .nav-link i { margin-left: 10px; font-style: normal; font-size: 1.2rem; }
        .main-content { margin-right: var(--sidebar-width); flex: 1; display: flex; flex-direction: column; min-width: 0; }
        .topbar { background: var(--white); height: 70px; display: flex; align-items: center; justify-content: space-between; padding: 0 40px; box-shadow: 0 2px 10px rgba(44,36,22,0.02); }
        .page-title { margin: 0; font-size: 1.2rem; font-weight: 800; }
        .user-menu a { color: #f44336; font-weight: 700; text-decoration: none; background: #ffebee; padding: 6px 16px; border-radius: 50px; font-size: .85rem; }
        .user-menu a:hover { background: #ffcdd2; }
        .content-area { padding: 40px; }
        /* Cards & Tables */
        .card { background: #fff; border-radius: 12px; padding: 24px; box-shadow: 0 4px 15px rgba(0,0,0,0.03); border: 1px solid var(--beige-dark); margin-bottom: 24px;}
        .table-responsive { overflow-x: auto; }
        table { width: 100%; border-collapse: collapse; text-align: right; }
        th { background: var(--beige); color: var(--text-soft); padding: 12px 16px; font-weight: 700; border-bottom: 2px solid var(--beige-dark); }
        td { padding: 14px 16px; border-bottom: 1px solid var(--beige-dark); font-weight: 500; }
        tr:hover td { background: #faf9f5; }
        .btn { display: inline-block; padding: 10px 20px; background: linear-gradient(135deg, var(--gold), var(--gold-light)); color: #fff; text-decoration: none; border-radius: 8px; font-weight: 700; border: none; cursor: pointer; transition: .2s; }
        .btn:hover { transform: translateY(-2px); box-shadow: 0 6px 15px rgba(184,150,46,0.25); }
        .form-label { display: block; font-weight: 700; margin-bottom: 8px; color: var(--text-dark); }
        .form-control { width: 100%; padding: 12px 16px; border: 2px solid var(--beige-dark); border-radius: 8px; font-family: 'Tajawal', sans-serif; margin-bottom: 16px; box-sizing: border-box; }
        .form-control:focus { border-color: var(--gold); outline: none; }
        .mobile-toggle { display: none; }
        .sidebar-overlay { 
            display: none; 
            position: fixed; inset: 0; 
            background: rgba(0,0,0,0.5); 
            z-index: 99; 
        }
        .sidebar-close { display: none; }

        /* Responsive */
        @@media(max-width: 768px){
            .sidebar { transform: translateX(100%); transition: .3s; }
            .sidebar.show { transform: translateX(0); }
            .sidebar.show ~ .sidebar-overlay { display: block; }
            .main-content { margin-right: 0; }
            .content-area { padding: 20px; }
            .mobile-toggle { display: block!important; background:none; border:none; font-size:1.5rem; cursor:pointer;}
            .sidebar-close { display: block!important; position: absolute; left: 15px; top: 15px; background: none; border: none; font-size: 1.5rem; color: var(--gold); cursor: pointer; }
        }
    </style>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .swal2-popup { border-radius: 12px; font-family: 'Tajawal', sans-serif; }
    </style>
    <script>
        function confirmDelete(form, message) {
            Swal.fire({
                title: 'هل أنت متأكد؟',
                text: message || 'لا يمكنك التراجع عن هذا الإجراء!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#f44336',
                cancelButtonColor: '#4a5c54',
                confirmButtonText: 'نعم، احذف',
                cancelButtonText: 'إلغاء',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
            return false;
        }
    </script>
</head>
<body>

    <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <button class="sidebar-close" onclick="document.getElementById('sidebar').classList.remove('show')">✕</button>
            <a href="/" style="text-decoration: none; display: flex; flex-direction: column; align-items: center; gap:8px;">
                <img src="/image/taj-el-waqar-logo.jpg" alt="تاج الوقار" style="width:70px;height:70px;border-radius:50%;object-fit:cover;border:3px solid var(--gold-pale)" />
                <div style="font-size: .9rem; color: var(--gold); font-weight: 800;">لوحة الإدارة</div>
            </a>
        </div>
        <a href="/Dashboard" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")">
            <i>📊</i> الرئيسية
        </a>
        <a href="/Dashboard/Students" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Students" ? "active" : "")">
            <i>👨‍🎓</i> الطلاب
        </a>
       
        <a href="/Dashboard/Halaqas" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Halaqas" ? "active" : "")">
            <i>🕌</i> الحلقات
        </a>
       
        <a href="/Dashboard/Teachers" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Teachers" ? "active" : "")">
            <i>👨‍🏫</i> المعلمون
        </a>
        <a href="/Dashboard/RegistrationRequests" class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "RegistrationRequests" ? "active" : "")">
            <i>📋</i> طلبات التسجيل
        </a>
        
        <div id="installContainer" style="display:none; padding:20px; border-top:1px solid var(--beige-dark); margin-top:auto;">
            <button id="installBtn" class="btn" style="width:100%; font-size:.85rem; padding:10px; background:var(--gold-pale); color:var(--gold); border:2px solid var(--gold); box-shadow:none;">
                📲 تثبيت الإدارة كطبيق
            </button>
        </div>
       
    </aside>
    <div class="sidebar-overlay" id="overlay" onclick="document.getElementById('sidebar').classList.remove('show')"></div>

    <main class="main-content">
        <header class="topbar">
            <div style="display:flex;align-items:center;gap:15px;">
                <button class="mobile-toggle" onclick="document.getElementById('sidebar').classList.toggle('show')">☰</button>
                <h1 class="page-title">@ViewData["Title"]</h1>
            </div>
            <div class="user-menu">
                <a href="/Auth/Logout">🚪 تسجيل الخروج</a>
            </div>
        </header>

        <div class="content-area">
            @RenderBody()
        </div>
    </main>

    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw-admin.js', { scope: '/Dashboard/' }).then(reg => {
                    console.log('Admin ServiceWorker registered with scope: /Dashboard/');
                }).catch(err => {
                    console.error('Admin ServiceWorker registration failed', err);
                });
            });
        }

        let deferredPrompt;
        const installBtn = document.getElementById('installBtn');
        const installContainer = document.getElementById('installContainer');

        window.addEventListener('beforeinstallprompt', (e) => {
            e.preventDefault();
            deferredPrompt = e;
            installContainer.style.display = 'block';

            installBtn.addEventListener('click', () => {
                installContainer.style.display = 'none';
                deferredPrompt.prompt();
                deferredPrompt.userChoice.then((choiceResult) => {
                    if (choiceResult.outcome === 'accepted') {
                        console.log('Admin accepted install');
                    }
                    deferredPrompt = null;
                });
            });
        });
    </script>
</body>
</html>
