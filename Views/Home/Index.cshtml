let deferredPrompt;
const installContainer = document.createElement('div');
installContainer.style.cssText = 'position:fixed;bottom:18px;left:14px;z-index:99999;display:none';
installContainer.innerHTML = '<button id="installBtn" class="bg" style="padding:10px 18px;font-size:13px;background:linear-gradient(135deg,#c9a24b,#a87b2e);box-shadow:0 4px 16px rgba(0,0,0,.3)">📲 تثبيت التطبيق</button>';
document.body.appendChild(installContainer);

window.addEventListener('beforeinstallprompt', (e) => {
    e.preventDefault();
    deferredPrompt = e;
    installContainer.style.display = 'block';
    document.getElementById('installBtn').addEventListener('click', () => {
        installContainer.style.display = 'none';
        deferredPrompt.prompt();
        deferredPrompt.userChoice.then((choiceResult) => {
            if (choiceResult.outcome === 'accepted') {
                console.log('User accepted install');
            }
            deferredPrompt = null;
        });
    });
});
</script>

<script>
// CHART DATA
const CI={},CT={};

function bldCh(cvId,si,ti,stuId){
  const el=document.getElementById(cvId);
  if(!el)return;
  if(CI[cvId])CI[cvId].destroy();
  const stuData=SD[stuId],sessions=stuData?stuData.sessions:[];
  const sorted=[...sessions];
  const labels=sorted.map(s=>s.date.substring(5));
  let data,label,type;
  if(ti===0){
    data=sorted.map(s=>s.memorizationScore||0);
    label='درجة الحفظ';type='line';
  }else if(ti===1){
    data=sorted.map(s=>s.isPresent?1:0);
    label='الحضور';type='bar';
  }else{
    data=sorted.map(s=>s.score||0);
    label='التقييم';type='line';
  }
  const clr=ti===0?'#22a06b':ti===1?'#c9a24b':'#2196F3';
  const bg=ti===0?'rgba(34,160,107,.15)':ti===1?'rgba(201,162,75,.15)':'rgba(33,150,243,.15)';
  CI[cvId]=new Chart(el,{
    type:type,data:{labels,datasets:[{label,data,borderColor:clr,backgroundColor:bg,borderWidth:2.5,pointBackgroundColor:clr,pointRadius:4,pointHoverRadius:6,fill:true,tension:0.4,borderRadius:type==='bar'?5:0}]},
    options:{responsive:true,maintainAspectRatio:false,plugins:{legend:{display:false},tooltip:{rtl:true,titleFont:{family:"'Cairo',sans-serif",size:11},bodyFont:{family:"'Cairo',sans-serif",size:12},callbacks:{label:c=>` ${c.parsed.y} ${label}`}}},scales:{x:{ticks:{color:'rgba(255,255,255,.4)',font:{family:"'Cairo',sans-serif",size:10}},grid:{color:'rgba(255,255,255,.05)'}},y:{beginAtZero:true,ticks:{color:'rgba(255,255,255,.4)',font:{family:"'Cairo',sans-serif",size:10}},grid:{color:'rgba(255,255,255,.05)'}}}}
  });
}

const SD={};
function togC(cid,wid,cvId,si,stuId){
  const card=document.getElementById(cid),wrap=document.getElementById(wid);
  const isOp=wrap.classList.contains('op');
  document.querySelectorAll('.chw').forEach(w=>w.classList.remove('op'));
  document.querySelectorAll('.stuc').forEach(c=>c.classList.remove('exp'));
  if(!isOp){wrap.classList.add('op');card.classList.add('exp');setTimeout(()=>bldCh(cvId,si,CT[cvId]||0,stuId),60)}
}

function swT(tabsId,cvId,ti,si,stuId){
  document.querySelectorAll(`#${tabsId} .ctab`).forEach((t,i)=>t.classList.toggle('on',i===ti));
  CT[cvId]=ti;bldCh(cvId,si,ti,stuId);
}

// PORTAL - REAL BACKEND
// Load saved phone
(function(){try{const p=localStorage.getItem('tajPhone');if(p)document.getElementById('pinp').value=p}catch(e){}})();

function showStu(){
  const v=document.getElementById('pinp').value.replace(/\D/g,'');
  if(v.length>=9){
    try{localStorage.setItem('tajPhone',v)}catch(e){}
    const wrap=document.getElementById('swrap');
    wrap.innerHTML='<div style="text-align:center;padding:20px;color:rgba(255,255,255,.5)"><i class="bi bi-hourglass-split" style="font-size:24px"></i><br>جاري البحث...</div>';
    wrap.classList.add('sh');
    fetch('/Home/GetParentData?phone='+encodeURIComponent(v))
      .then(r=>r.json())
      .then(d=>{
        wrap.innerHTML='';
        if(d.success){
          let si=0;
          d.halaqat.forEach(h=>{
            h.students.forEach(stu=>{
              if(stu.isMyChild){
                SD[stu.id]={sessions:stu.sessions||[],awjoh:stu.awjoh,targetPages:stu.targetPages};
                const cardId='s'+stu.id;
                const chartId='cv'+stu.id;
                const wrapId='c'+stu.id;
                const tabsId='ct'+stu.id;
                const genderColor=stu.gender==='Female'?'linear-gradient(135deg,#1a3a66,#c9a24b)':'linear-gradient(135deg,#1a7a50,#c9a24b)';
                const names=stu.name.split(' ');
                const initial=names.map(s=>s[0]).join('').substring(0,2);
                const pct=stu.targetPages>0?Math.round(stu.awjoh/stu.targetPages*100):0;
                const avatarHtml=stu.profileImageUrl?`<img src="${stu.profileImageUrl}" class="stua-img" alt="">`:`<div class="stua" style="background:${genderColor}">${initial}</div>`;
                wrap.innerHTML+=`
                  <div class="stuc" id="${cardId}">
                    <div class="stuh" onclick="togC('${cardId}','${wrapId}','${chartId}',${si},${stu.id})">
                      ${avatarHtml}
                      <div style="flex:1;min-width:0">
                        <div class="stun">${stu.name}</div>
                        <div class="stulv">${h.name} · ${h.sheikh}</div>
                        <div class="stubg"><span class="sbg bgr">${stu.attendance>=80?'منتظم':'غير منتظم'}</span></div>
                      </div>
                      <button class="exb"><i class="bi bi-chevron-down"></i></button>
                    </div>
                    <div class="stust">
                      <div class="ss2"><span class="ssv">${pct}%</span><div class="ssl">الإنجاز</div></div>
                      <div class="ss2"><span class="ssv">${stu.awjoh||0}</span><div class="ssl">وجها</div></div>
                      <div class="ss2"><span class="ssv">${stu.attendance}%</span><div class="ssl">الحضور</div></div>
                      <div class="ss2"><span class="ssv">${stu.points||0}</span><div class="ssl">النقاط</div></div>
                    </div>
                    <div class="chw" id="${wrapId}">
                      <div class="chi">
                        <div class="ctabs" id="${tabsId}">
                          <button class="ctab" onclick="swT('${tabsId}','${chartId}',0,${si},${stu.id})">الحفظ</button>
                          <button class="ctab" onclick="swT('${tabsId}','${chartId}',1,${si},${stu.id})">الحضور</button>
                          <button class="ctab on" onclick="swT('${tabsId}','${chartId}',2,${si},${stu.id})">الانتظام</button>
                        </div>
                        <div class="ccw"><canvas id="${chartId}"></canvas></div>
                      </div>
                    </div>
                  </div>
                `;
                si++;
              }
            });
          });
          const firstCard=wrap.querySelector('.stuc');
          if(firstCard){
            firstCard.classList.add('exp');
            const firstChart=firstCard.querySelector('.chw');
            if(firstChart)firstChart.classList.add('op');
            setTimeout(()=>{
              const fc=firstCard.querySelector('.ccw canvas');
              if(fc)setTimeout(()=>bldCh(fc.id,2,2,parseInt(fc.id.replace('cv',''))),60);
            },100);
          }
          toast('تم العثور على بيانات أبنائك ✓');
          setTimeout(()=>wrap.scrollIntoView({behavior:'smooth',block:'nearest'}),200);
        } else {
          wrap.innerHTML='<div style="text-align:center;padding:20px;color:rgba(255,255,255,.5)">لم يتم العثور على بيانات لهذا الرقم</div>';
          toast('لم يتم العثور على بيانات');
        }
      })
      .catch(()=>{
        wrap.innerHTML='<div style="text-align:center;padding:20px;color:rgba(255,255,255,.5)">حدث خطأ في الاتصال</div>';
        toast('حدث خطأ في الاتصال');
      });
  } else toast('يرجى إدخال رقم هاتف صحيح');
}
document.getElementById('pinp').addEventListener('keydown',e=>{if(e.key==='Enter')showStu()});

// NAV
const navEl=document.getElementById('nav');
const ham=document.getElementById('nh'),mob=document.getElementById('mob'),ovl=document.getElementById('ovl');
if(ham)ham.addEventListener('click',()=>{const op=mob.classList.toggle('op');ovl.classList.toggle('sh',op);ham.classList.toggle('op',op)});
function cm(){if(mob)mob.classList.remove('op');if(ovl)ovl.classList.remove('sh');if(ham)ham.classList.remove('op')}
let lastScroll=0;
window.addEventListener('scroll',()=>{
  const sy=scrollY;
  if(navEl){
    navEl.classList.toggle('sc',sy>52);
    if(sy<=10){navEl.style.transform='translateY(0)'}
    else{navEl.style.transform=sy>lastScroll&&sy>80?'translateY(-100%)':'translateY(0)'}
  }
  const ps=document.getElementById('pstrip');
  if(ps){
    if(sy<=10){ps.style.transform='translateY(0)'}
    else{ps.style.transform=sy>lastScroll&&sy>120?'translateY(-100%)':'translateY(0)'}
  }
  lastScroll=sy;
},{passive:true});

// FAQ
function ft(el){const i=el.parentElement;const o=i.classList.contains('op');document.querySelectorAll('.fi').forEach(x=>x.classList.remove('op'));if(!o)i.classList.add('op')}

// CAROUSEL
let tc=0;
function ts(d){tc=(tc+d+3)%3;tu()}
function tg(i){tc=i;tu()}
function tu(){document.getElementById('ttr').style.transform=`translateX(${tc*100}%)`;document.querySelectorAll('.td').forEach((d,i)=>d.classList.toggle('on',i===tc))}
setInterval(()=>ts(1),5500);

// FORM
function clearFieldErrors(){
  document.querySelectorAll('.ferr').forEach(e=>e.textContent='');
  document.querySelectorAll('.fin').forEach(e=>e.style.borderColor='transparent');
}
function showFieldError(id,msg){
  document.getElementById(id).textContent=msg;
  const input=id.replace('Err','');
  const el=document.getElementById(input);
  if(el)el.style.borderColor='#e53935';
}
function isValidEgyptianPhone(phone){
  return /^01[0125]\d{8}$/.test(phone.replace(/\D/g,''));
}
function submitRegistrationForm(){
  clearFieldErrors();
  const btn=document.getElementById('regSubmitBtn');
  const name=document.getElementById('regStudentName').value.trim();
  const pname=document.getElementById('regParentName').value.trim();
  const phone=document.getElementById('regParentPhone').value.trim();
  let valid=true;
  if(!name){showFieldError('nameErr','هذا الحقل مطلوب');valid=false}
  if(!pname){showFieldError('parentNameErr','هذا الحقل مطلوب');valid=false}
  if(!phone){showFieldError('phoneErr','هذا الحقل مطلوب');valid=false}
  else if(!isValidEgyptianPhone(phone)){showFieldError('phoneErr','رقم مصري صحيح: 01xxxxxxxxx (11 رقمًا)');valid=false}
  if(!valid)return;
  const formData=new FormData(document.getElementById('regForm'));
  btn.innerHTML='<i class="bi bi-hourglass-split"></i> جاري الإرسال...';btn.disabled=true;
  fetch('/Home/SubmitRegistration',{method:'POST',body:formData})
    .then(r=>r.json())
    .then(d=>{
      if(d.success){
        btn.innerHTML='<i class="bi bi-check-circle-fill"></i> تم إرسال الطلب بنجاح!';
        btn.style.background='linear-gradient(135deg,#22a06b,#0d5c3a)';
        toast(d.message);
        document.getElementById('regForm').reset();
        clearFieldErrors();
      } else {
        btn.innerHTML='<i class="bi bi-send-fill"></i> إرسال طلب التسجيل';
        btn.disabled=false;
        toast(d.message||'حدث خطأ');
      }
    })
    .catch(()=>{
      btn.innerHTML='<i class="bi bi-send-fill"></i> إرسال طلب التسجيل';
      btn.disabled=false;
      toast('حدث خطأ في الاتصال');
    });
}

// PRESELECT HALAQA
function preselectH(keyword){
  const s=document.getElementById('halSel');
  for(let i=0;i<s.options.length;i++){if(s.options[i].text.includes(keyword)){s.selectedIndex=i;break}}
  document.getElementById('reg').scrollIntoView({behavior:'smooth'});
}

// TOAST
function toast(msg){
  const t=document.getElementById('toast');
  document.getElementById('tmsg').textContent=msg;
  t.style.display='flex';
  requestAnimationFrame(()=>{t.style.opacity='1';t.style.transform='translateY(0)'});
  setTimeout(()=>{t.style.opacity='0';t.style.transform='translateY(14px)';setTimeout(()=>t.style.display='none',300)},3200);
}

// REVEAL
const ro=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in')}),{threshold:.08});
document.querySelectorAll('.rv').forEach(el=>ro.observe(el));
</script>
