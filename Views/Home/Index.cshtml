@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0">
<title>تاج الوقار | حيث يبدأ طريق أهل القرآن</title>
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#0d5c3a">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<link rel="apple-touch-icon" href="/image/taj-el-waqar-logo.jpg">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&family=Scheherazade+New:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.11.3/font/bootstrap-icons.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<style>
:root{
  --em:#0d5c3a;--em-d:#093d27;--em-m:#1a7a50;--em-l:#22a06b;--em-g:rgba(13,92,58,.12);
  --nv:#0b1f3a;--nv-m:#112d54;
  --gd:#c9a24b;--gd-l:#e2c07a;--gd-p:rgba(201,162,75,.12);
  --wh:#fff;--ow:#f8f9fb;--sg:#f1f4f8;
  --tx:#0b1f3a;--tm:#6b7a90;--tl:#9aa5b8;
  --bd:rgba(201,162,75,.2);
  --s0:0 2px 12px rgba(11,31,58,.06);--s1:0 8px 32px rgba(11,31,58,.10);--s2:0 20px 60px rgba(11,31,58,.14);
  --r1:8px;--r2:14px;--r3:22px;--r4:30px;
  --fd:'Scheherazade New',serif;--fb:'Cairo',sans-serif;
  --tr:all .3s cubic-bezier(.4,0,.2,1);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;-webkit-tap-highlight-color:transparent}
body{font-family:var(--fb);color:var(--tx);background:var(--wh);direction:rtl;overflow-x:hidden;line-height:1.7;font-size:15px}
a{text-decoration:none;color:inherit}
section{position:relative;overflow:hidden}

.w{width:100%;max-width:1280px;margin:0 auto;padding:0 16px}
@@media(min-width:640px){.w{padding:0 28px}}
@@media(min-width:1024px){.w{padding:0 48px}}

.sec{padding:60px 0}
@@media(min-width:768px){.sec{padding:96px 0}}

.tag{display:inline-flex;align-items:center;gap:7px;background:var(--gd-p);border:1px solid var(--bd);color:var(--gd);font-size:12px;font-weight:600;padding:5px 14px;border-radius:50px;margin-bottom:14px}
.tag::before{content:'';width:5px;height:5px;border-radius:50%;background:var(--gd)}
.st{font-size:clamp(22px,5vw,40px);font-weight:800;color:var(--nv);line-height:1.25;margin-bottom:12px}
.ss{font-size:14px;color:var(--tm);line-height:1.85;max-width:560px}
.tc .ss{margin:0 auto}
.tc{text-align:center}

.bg{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:linear-gradient(135deg,var(--em-m),var(--em-d));color:#fff!important;border:none;border-radius:50px;padding:12px 24px;font-size:13px;font-weight:700;font-family:var(--fb);cursor:pointer;transition:var(--tr);box-shadow:0 4px 16px rgba(13,92,58,.28);white-space:nowrap;text-decoration:none}
.bg:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(13,92,58,.38)}
.bg:active{transform:translateY(0)}
.bg-l{padding:14px 30px;font-size:15px}
.bo{display:inline-flex;align-items:center;justify-content:center;gap:8px;background:transparent;color:rgba(255,255,255,.85)!important;border:1.5px solid rgba(255,255,255,.25);border-radius:50px;padding:11px 24px;font-size:13px;font-weight:600;font-family:var(--fb);cursor:pointer;transition:var(--tr);white-space:nowrap;text-decoration:none}
.bo:hover{border-color:var(--gd);color:var(--gd-l)!important}

.pe{position:absolute;inset:0;pointer-events:none;z-index:0;opacity:.03;background-image:url("data:image/svg+xml,%3Csvg width='80' height='80' viewBox='0 0 80 80' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='%230d5c3a'%3E%3Cpath d='M40 0L50 20L40 15L30 20Z'/%3E%3Cpath d='M40 80L50 60L40 65L30 60Z'/%3E%3Cpath d='M0 40L20 30L15 40L20 50Z'/%3E%3Cpath d='M80 40L60 30L65 40L60 50Z'/%3E%3C/g%3E%3Ccircle cx='40' cy='40' r='14' fill='none' stroke='%230d5c3a' stroke-width='.8'/%3E%3C/svg%3E");background-size:80px}
.pg{position:absolute;inset:0;pointer-events:none;z-index:0;opacity:.03;background-image:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' stroke='%23c9a24b' stroke-width='.7'%3E%3Cpolygon points='30,4 56,19 56,49 30,57 4,49 4,19'/%3E%3Cpolygon points='30,14 46,23 46,43 30,49 14,43 14,23'/%3E%3C/g%3E%3C/svg%3E");background-size:60px}

/* NAV */
#nav{position:fixed;inset:0 0 auto;z-index:9999;transition:background .3s ease,box-shadow .3s ease,transform .35s ease;background:transparent}
#nav.sc{background:rgba(11,31,58,.96);backdrop-filter:blur(18px);box-shadow:var(--s1)}
.nw{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;gap:10px}
@@media(min-width:640px){.nw{padding:14px 28px}}
@@media(min-width:1024px){.nw{padding:15px 48px}}
.nl{display:flex;align-items:center;gap:9px;flex-shrink:0}
.ni{width:36px;height:36px;border-radius:9px;flex-shrink:0;background:linear-gradient(135deg,var(--em),var(--gd));display:flex;align-items:center;justify-content:center;font-size:17px;box-shadow:0 3px 10px rgba(13,92,58,.3)}
.ni-img{width:36px;height:36px;border-radius:50%;flex-shrink:0;object-fit:cover;border:2px solid rgba(255,255,255,.2)}
.nn{font-family:var(--fd);font-size:18px;font-weight:700;color:#fff;transition:var(--tr)}
.nb{font-size:9px;color:var(--gd-l);transition:var(--tr)}
#nav.sc .nn{color:#fff}
#nav.sc .nb{color:var(--gd-l)}
.nlks{display:none;list-style:none;gap:2px;align-items:center}
@@media(min-width:1050px){.nlks{display:flex}}
.nlks a{font-size:12px;font-weight:500;color:rgba(255,255,255,.82);padding:6px 10px;border-radius:7px;transition:var(--tr)}
#nav.sc .nlks a{color:rgba(255,255,255,.9)}
.nlks a:hover{background:var(--gd-p);color:var(--gd)!important}
.nr{display:flex;align-items:center;gap:8px;flex-shrink:0}
.nc{display:none}
@@media(min-width:520px){.nc{display:flex}}
.nc .bg{padding:8px 16px;font-size:12px;background:linear-gradient(135deg,var(--gd),#a87b2e);box-shadow:0 3px 12px rgba(201,162,75,.3)}
.nh{background:none;border:none;cursor:pointer;width:36px;height:36px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;border-radius:8px}
@@media(min-width:1050px){.nh{display:none}}
.nh span{width:21px;height:2px;background:#fff;border-radius:2px;transition:var(--tr);display:block}
#nav.sc .nh span{background:#fff}
.nh.op span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.nh.op span:nth-child(2){opacity:0}
.nh.op span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

/* MOBILE MENU */
#mob{position:fixed;inset:0 0% 0 auto;right:0;width:85%;max-width:320px;z-index:9998;background:var(--nv);padding:76px 22px 32px;transform:translateX(110%);transition:transform .35s ease;display:flex;flex-direction:column;gap:4px;box-shadow:-4px 0 30px rgba(0,0,0,.35);overflow-y:auto}
#mob.op{transform:translateX(0)}
#mob a{color:rgba(255,255,255,.78);font-size:14px;font-weight:500;padding:11px 14px;border-radius:9px;transition:var(--tr);border-right:3px solid transparent}
#mob a:hover{background:rgba(255,255,255,.06);border-right-color:var(--gd);color:var(--gd-l)}
.mcta{margin-top:14px}
.mcta .bg{width:100%;padding:13px;font-size:14px}
#ovl{position:fixed;inset:0;z-index:9997;background:rgba(0,0,0,.5);display:none;backdrop-filter:blur(2px)}
#ovl.sh{display:block}

/* HERO */
#hero{min-height:100svh;background:linear-gradient(155deg,var(--nv) 0%,var(--em-d) 55%,var(--nv-m) 100%);display:flex;align-items:center;padding:106px 0 72px}
.orb{position:absolute;border-radius:50%;pointer-events:none;filter:blur(80px);z-index:0}
.o1{width:500px;height:500px;top:-180px;left:-180px;background:radial-gradient(circle,rgba(13,92,58,.4) 0%,transparent 70%)}
.o2{width:350px;height:350px;bottom:-80px;right:5%;background:radial-gradient(circle,rgba(201,162,75,.12) 0%,transparent 70%)}
.hi{position:relative;z-index:2}
.hbg{display:inline-flex;align-items:center;gap:8px;background:rgba(201,162,75,.14);border:1px solid rgba(201,162,75,.3);color:var(--gd-l);font-size:11px;font-weight:500;padding:5px 15px;border-radius:50px;margin-bottom:18px}
.bd{width:6px;height:6px;border-radius:50%;background:var(--gd-l);animation:pulse 2s infinite}
@@keyframes pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.5;transform:scale(1.4)}}
.ht{font-family:var(--fd);font-size:clamp(48px,13vw,96px);font-weight:700;color:#fff;line-height:1.05;margin-bottom:10px}
.gt{background:linear-gradient(135deg,var(--gd-l),var(--gd));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.htag{font-size:clamp(13px,3vw,19px);color:rgba(255,255,255,.62);font-style:italic;margin-bottom:16px;font-family:var(--fd)}
.hdesc{font-size:13px;line-height:1.9;color:rgba(255,255,255,.6);max-width:460px;margin-bottom:26px}

/* HERO PORTAL CTA BANNER */
.hpcta{background:rgba(201,162,75,.14);border:1px solid rgba(201,162,75,.3);border-radius:var(--r3);padding:16px 18px;margin-bottom:26px;display:flex;align-items:center;gap:12px;flex-wrap:wrap}
.hpcta .ico{font-size:26px;flex-shrink:0}
.hpcta .txt{flex:1;min-width:150px}
.hpcta .txt strong{display:block;font-size:14px;color:#fff;font-weight:700;margin-bottom:1px}
.hpcta .txt span{font-size:11px;color:rgba(255,255,255,.52)}
.hpcta .bg{padding:9px 18px;font-size:12px;flex-shrink:0;background:linear-gradient(135deg,var(--gd),#a87b2e);box-shadow:0 3px 12px rgba(201,162,75,.3)}

.hbtns{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:36px}
.hbtns .bg-l{font-size:14px}
.hbtns .bo{font-size:14px}

.hss{display:flex;flex-wrap:wrap;border-top:1px solid rgba(255,255,255,.1);padding-top:26px;gap:0}
.hs{flex:1;min-width:70px;padding:0 12px 0 0;border-left:1px solid rgba(255,255,255,.08)}
.hs:first-child{padding-right:0}
.hs:last-child{border-left:none;padding-left:12px}
.hv{font-size:26px;font-weight:900;color:#fff;line-height:1}
.hv span{color:var(--gd-l)}
.hl{font-size:10px;color:rgba(255,255,255,.4);margin-top:3px}

.sci{position:absolute;bottom:22px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:5px;color:rgba(255,255,255,.3);font-size:9px;z-index:2}
.sw{width:19px;height:30px;border:1.5px solid rgba(255,255,255,.18);border-radius:10px;display:flex;justify-content:center;padding-top:5px}
.sd{width:3px;height:5px;background:rgba(255,255,255,.38);border-radius:2px;animation:sda 2s infinite}
@@keyframes sda{0%{transform:translateY(0);opacity:1}100%{transform:translateY(10px);opacity:0}}

/* STICKY PORTAL STRIP */
#pstrip{background:linear-gradient(135deg,var(--em),var(--nv));padding:0;position:sticky;top:62px;z-index:998;box-shadow:0 4px 20px rgba(0,0,0,.25);transition:transform .35s ease}
.psi{display:flex;align-items:center;justify-content:space-between;padding:11px 16px;gap:10px;flex-wrap:wrap}
@@media(min-width:640px){.psi{padding:11px 28px}}
.pst{display:flex;align-items:center;gap:9px}
.pst .ico{font-size:20px}
.pst .lbl{font-size:12px;font-weight:700;color:#fff}
.pst .sub{font-size:10px;color:rgba(255,255,255,.5);display:none}
@@media(min-width:420px){.pst .sub{display:block}}
.pstrip-btn .bg{padding:8px 16px;font-size:12px;background:linear-gradient(135deg,var(--gd),#a87b2e);box-shadow:0 3px 10px rgba(201,162,75,.3)}

/* ABOUT */
#about{background:var(--wh)}
.ag{display:grid;grid-template-columns:1fr;gap:32px;align-items:center}
@@media(min-width:900px){.ag{grid-template-columns:1fr 1fr}}
.aimg{height:320px;border-radius:var(--r3);background:linear-gradient(145deg,var(--em-d),var(--nv));display:flex;flex-direction:column;align-items:center;justify-content:center;gap:10px;font-size:60px;color:rgba(255,255,255,.25);position:relative;overflow:hidden}
@@media(min-width:768px){.aimg{height:400px}}
.aimg em{font-size:13px;font-family:var(--fd);color:rgba(255,255,255,.28);font-style:normal}
.aimg-logo{width:80px;height:80px;border-radius:50%;object-fit:cover;border:3px solid rgba(255,255,255,.2);box-shadow:0 4px 20px rgba(0,0,0,.3)}
.abadge{position:absolute;bottom:16px;right:16px;left:16px;background:rgba(255,255,255,.97);border-radius:var(--r2);padding:13px 16px;display:flex;align-items:center;gap:11px;box-shadow:var(--s1)}
.abv{font-size:16px;font-weight:800;color:var(--nv)}
.abl{font-size:11px;color:var(--tm)}
.afs{display:flex;flex-direction:column;gap:11px;margin-top:22px}
.af{display:flex;align-items:flex-start;gap:11px;padding:13px;border-radius:var(--r2);border:1px solid var(--sg);transition:var(--tr)}
.af:hover{border-color:var(--bd);box-shadow:var(--s0)}
.afic{width:40px;height:40px;border-radius:10px;flex-shrink:0;background:var(--gd-p);color:var(--gd);display:flex;align-items:center;justify-content:center;font-size:18px}
.aft{font-size:13px;font-weight:700;color:var(--nv);margin-bottom:3px}
.afd{font-size:12px;color:var(--tm);line-height:1.7}

/* SERVICES */
#srv{background:var(--ow)}
.sg2{display:grid;grid-template-columns:repeat(2,1fr);gap:11px;margin-top:36px}
@@media(min-width:580px){.sg2{grid-template-columns:repeat(3,1fr);gap:14px}}
@@media(min-width:1024px){.sg2{grid-template-columns:repeat(4,1fr)}}
.sc{background:var(--wh);border-radius:var(--r3);padding:20px 16px;border:1px solid transparent;box-shadow:var(--s0);transition:var(--tr);position:relative;overflow:hidden}
.sc::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,var(--em-d),var(--em-m));opacity:0;transition:var(--tr);z-index:0}
.sc:hover{transform:translateY(-4px);box-shadow:var(--s2)}
.sc:hover::before{opacity:1}
.sc:hover .sci2{background:rgba(255,255,255,.14);color:var(--gd-l)}
.sc:hover .sct{color:#fff}
.sc:hover .scd{color:rgba(255,255,255,.62)}
.sci2{width:44px;height:44px;border-radius:10px;background:var(--gd-p);color:var(--gd);display:flex;align-items:center;justify-content:center;font-size:19px;margin-bottom:13px;position:relative;z-index:1;transition:var(--tr)}
.sct{font-size:12px;font-weight:700;color:var(--nv);margin-bottom:6px;position:relative;z-index:1;transition:var(--tr)}
.scd{font-size:11px;color:var(--tm);line-height:1.7;position:relative;z-index:1;transition:var(--tr)}

/* HALAQAS */
#hal{background:var(--wh)}
.hg{display:grid;grid-template-columns:1fr;gap:14px;margin-top:36px}
@@media(min-width:580px){.hg{grid-template-columns:repeat(2,1fr)}}
@@media(min-width:900px){.hg{grid-template-columns:repeat(3,1fr)}}

.hc{background:var(--wh);border-radius:var(--r3);overflow:hidden;box-shadow:var(--s1);border:1px solid var(--sg);transition:var(--tr)}
.hc:hover{transform:translateY(-3px);box-shadow:var(--s2)}
.hch{padding:18px 16px 13px;border-bottom:1px solid var(--sg)}
.hlv{display:inline-flex;align-items:center;gap:5px;font-size:9px;font-weight:700;padding:3px 9px;border-radius:50px;margin-bottom:8px}
.lv0{background:rgba(236,72,153,.1);color:#ec4899}
.lv1{background:rgba(245,158,11,.1);color:#d97706}
.lv2{background:rgba(34,160,107,.12);color:var(--em-l)}
.lv3{background:rgba(99,102,241,.1);color:#6366f1}
.hn{font-size:15px;font-weight:800;color:var(--nv);margin-bottom:4px}
.htr{font-size:11px;color:var(--tm);display:flex;align-items:center;gap:4px}
.hb{padding:14px 16px}
.hi2{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:12px}
.hil{font-size:9px;color:var(--tl);font-weight:600;text-transform:uppercase;letter-spacing:.4px;margin-bottom:1px}
.hiv{font-size:12px;font-weight:700;color:var(--nv)}
.cpl{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px}
.cpt{font-size:11px;font-weight:600;color:var(--nv)}
.cpc{font-size:11px;color:var(--tm)}
.cpb{height:7px;background:var(--sg);border-radius:4px;overflow:hidden}
.cpf{height:100%;border-radius:4px;transition:width .8s ease}
.cf-g{background:linear-gradient(to left,var(--em-l),var(--em-m))}
.cf-y{background:linear-gradient(to left,#f59e0b,#d97706)}
.cf-r{background:linear-gradient(to left,#ef4444,#dc2626)}
.cps{display:inline-flex;align-items:center;gap:4px;font-size:10px;font-weight:600;margin-top:7px;padding:3px 9px;border-radius:50px}
.st-o{background:rgba(34,160,107,.1);color:var(--em-l)}
.st-f{background:rgba(245,158,11,.1);color:#d97706}
.st-x{background:rgba(239,68,68,.1);color:#ef4444}
.hfoot{padding:12px 16px;border-top:1px solid var(--sg);display:flex;align-items:center;justify-content:space-between;gap:8px}
.hfoot .bg{padding:8px 16px;font-size:11px}
.hfoot .bg:disabled{opacity:.45;cursor:not-allowed;pointer-events:none}
.hstu{display:flex;align-items:center}
.hav{width:24px;height:24px;border-radius:50%;border:2px solid var(--wh);background:linear-gradient(135deg,var(--em),var(--gd));display:flex;align-items:center;justify-content:center;font-size:9px;font-weight:700;color:#fff;margin-left:-5px}
.hav:first-child{margin-left:0}
.hav-m{background:var(--sg);color:var(--tm);font-size:8px}

/* LOCATIONS */
#loc{background:var(--ow)}
.lg{display:grid;grid-template-columns:1fr;gap:14px;margin-top:36px}
@@media(min-width:640px){.lg{grid-template-columns:repeat(2,1fr)}}
.lc{border-radius:var(--r3);overflow:hidden;box-shadow:var(--s1);transition:var(--tr);border:1px solid var(--sg)}
.lc:hover{transform:translateY(-3px);box-shadow:var(--s2)}
.lm{height:150px;background:linear-gradient(135deg,var(--nv),var(--nv-m));display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.lm::before{content:'';position:absolute;inset:0;opacity:.06;pointer-events:none;background-image:linear-gradient(rgba(201,162,75,1) 1px,transparent 1px),linear-gradient(90deg,rgba(201,162,75,1) 1px,transparent 1px);background-size:24px 24px}
.lpin{font-size:34px;animation:pb 2s ease-in-out infinite}
@@keyframes pb{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}
.li{padding:18px 16px}
.lb{display:inline-flex;align-items:center;gap:4px;background:var(--em-g);color:var(--em-m);font-size:10px;font-weight:600;padding:3px 9px;border-radius:50px;margin-bottom:7px}
.ln{font-size:17px;font-weight:800;color:var(--nv);margin-bottom:8px}
.ld{font-size:12px;color:var(--tm);line-height:1.9}
.llk{display:inline-flex;align-items:center;gap:5px;margin-top:11px;color:var(--em-m);font-size:12px;font-weight:700;transition:var(--tr)}
.llk:hover{color:var(--gd);gap:9px}

/* PORTAL */
#portal{background:linear-gradient(155deg,var(--nv),var(--em-d))}
#portal .st{color:#fff}
#portal .ss{color:rgba(255,255,255,.56)}
#portal .tag{background:rgba(201,162,75,.14);border-color:rgba(201,162,75,.3)}
.pbox{background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.1);backdrop-filter:blur(16px);border-radius:var(--r4);padding:22px 16px;box-shadow:0 24px 60px rgba(0,0,0,.25)}
@@media(min-width:640px){.pbox{padding:34px 30px}}
.ph h4{font-size:16px;font-weight:700;color:#fff;margin-bottom:3px}
.ph p{font-size:12px;color:rgba(255,255,255,.4);margin-bottom:18px}
.pr{display:flex;gap:9px;flex-wrap:wrap}
