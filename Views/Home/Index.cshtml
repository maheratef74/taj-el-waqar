<!-- HALAQAS -->
<section id="hal" class="sec">
  <div class="pe" style="opacity:.018"></div>
  <div class="w">
    <div class="tc rv">
      <div class="tag">الحلقات المتاحة</div>
      <h2 class="st">اختر الحلقة المناسبة لابنك</h2>
      <p class="ss">كل حلقة محدودة الأماكن لضمان أعلى جودة في التعليم والمتابعة الفردية.</p>
    </div>
    <div class="hg">
      @if (ViewBag.Halaqas != null)
      {
          int hi = 0;
          var levelIcons = new Dictionary<string, string> { {"مبتدئ", "🧒"}, {"متوسط", "📖"}, {"متقدم", "⭐"}, {"تجويد", "🎓"} };
          var levelClasses = new Dictionary<string, string> { {"مبتدئ", "lv0"}, {"متوسط", "lv1"}, {"متقدم", "lv2"}, {"تجويد", "lv3"} };
          var levelNames = new Dictionary<string, string> { {"مبتدئ", "للأطفال"}, {"متوسط", "متوسط"}, {"متقدم", "متقدم"}, {"تجويد", "تجويد"} };
          foreach (var halaqa in ViewBag.Halaqas)
          {
              var lvl = (string?)halaqa.Level ?? "مبتدئ";
              var icon = levelIcons.ContainsKey(lvl) ? levelIcons[lvl] : "🧒";
              var lvlClass = levelClasses.ContainsKey(lvl) ? levelClasses[lvl] : "lv0";
              var lvlName = levelNames.ContainsKey(lvl) ? levelNames[lvl] : lvl;
              var teacherName = halaqa.Teacher != null ? halaqa.Teacher.Name : "غير محدد";
              var currentStudents = halaqa.Students != null ? ((IEnumerable<object>)halaqa.Students).Count() : 0;
              var capacity = halaqa.MaxCapacity > 0 ? halaqa.MaxCapacity : 20;
              var pct = capacity > 0 ? Math.Min(100, (int)((double)currentStudents / capacity * 100)) : 0;
              var remaining = capacity - currentStudents;
              string statusClass, statusText;
              if (remaining <= 0) { statusClass = "st-x"; statusText = "الحلقة ممتلئة — قائمة انتظار"; }
              else if (remaining <= 3) { statusClass = "st-f"; statusText = "الأماكن تنفد — " + remaining + " فقط"; }
              else { statusClass = "st-o"; statusText = "متاح — " + remaining + (remaining == 1 ? " مكان" : " أماكن") + " شاغرة"; }
              string barClass = pct >= 100 ? "cf-r" : pct >= 80 ? "cf-y" : "cf-g";
              var isFull = remaining <= 0;
              var delay = hi % 2 == 0 ? "rv1" : "rv2";
              var hname = halaqa.Name;
              <div class="hc rv @delay">
                <div class="hch"><span class="hlv @lvlClass">@icon @lvlName</span><div class="hn">@hname</div><div class="htr"><i class="bi bi-person-fill" style="color:var(--gd)"></i> @teacherName</div></div>
                <div class="hb">
                  <div class="hi2">
                    <div><div class="hil">الأعمار</div><div class="hiv">@(!string.IsNullOrEmpty(halaqa.AgeRange) ? halaqa.AgeRange : "جميع الأعمار")</div></div>
                    <div><div class="hil">الموعد</div><div class="hiv">@(!string.IsNullOrEmpty(halaqa.Schedule) ? halaqa.Schedule : "يوميًا")</div></div>
                    <div><div class="hil">الوقت</div><div class="hiv">@(!string.IsNullOrEmpty(halaqa.ClassTime) ? halaqa.ClassTime : "—")</div></div>
                    <div><div class="hil">الفرع</div><div class="hiv">@(!string.IsNullOrEmpty(halaqa.Location) ? halaqa.Location : "—")</div></div>
                  </div>
                  <div class="cpl"><span class="cpt">سعة الحلقة</span><span class="cpc">@currentStudents / @capacity طالب</span></div>
                  <div class="cpb"><div class="cpf @barClass" style="width:@pct%"></div></div>
                  <div><span class="cps @statusClass"><i class="bi bi-circle-fill" style="font-size:6px"></i> @statusText</span></div>
                </div>
                <div class="hfoot">
                  <div class="hstu">
                    @if (currentStudents > 0 && halaqa.Students != null)
                    {
                        int maxAv = 3;
                        int shown = 0;
                        foreach (var stu in (IEnumerable<object>)halaqa.Students)
                        {
                            if (shown >= maxAv) break;
                            var sname = (string?)stu.GetType().GetProperty("Name")?.GetValue(stu) ?? "";
                            var initial = sname.Length > 0 ? sname.Substring(0, 1) : "?";
                            <div class="hav">@initial</div>
                            shown++;
                        }
                        if (currentStudents > maxAv)
                        {
                            <div class="hav hav-m">+@(currentStudents - maxAv)</div>
                        }
                    }
                  </div>
                  @if (isFull)
                  {
                      <button class="bg" disabled>ممتلئة</button>
                  }
                  else
                  {
                      <a href="#reg" class="bg" onclick="preselectH('@hname')">سجل الآن</a>
                  }
                </div>
              </div>
              hi++;
          }
      }
    </div>
  </div>
</section>

